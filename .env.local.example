# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# OpenAI
OPENAI_API_KEY=sk-your-openai-key

# Stripe
STRIPE_SECRET_KEY=sk_live_or_test_your-stripe-secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_or_test_your-stripe-publishable
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_SOLO_PRICE_ID=price_your_solo_consultant_price_id
STRIPE_SME_PRICE_ID=price_your_sme_price_id
STRIPE_AGENCY_PRICE_ID=price_your_agency_price_id

# App
NEXT_PUBLIC_APP_URL=https://your-domain.com

# Opportunity source APIs (optional; required if you enable live scanning)
CONTRACTS_FINDER_API_URL=https://contracts-finder.service.gov.uk
FIND_A_TENDER_API_URL=https://www.find-tender.service.gov.uk
TED_API_URL=https://ted.europa.eu
SAM_GOV_API_URL=https://api.sam.gov
SAM_GOV_API_KEY=your-sam-gov-api-key

# Scheduled scanning (optional; required if you call /api/opportunities/scheduled-scan)
OPPORTUNITY_SCAN_CRON_SECRET=your-cron-secret
